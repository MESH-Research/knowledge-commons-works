msgstr "Collection already included."

msgid "Community inclusion"
msgstr "Collection inclusion"

msgid "Community invitation"
msgstr "Collection invitation"

msgid "Community manage record"
msgstr "Collection manage record"

msgid ""
"Community managers and administrators can enable the dashboard from the "
"community settings page"
msgstr ""
"Collection managers and administrators can enable the dashboard from the "
"collection settings page"

msgid "Community must be defined."
msgstr "Collection must be defined."

msgid "Community not found."
msgstr "Collection not found."

msgid "Community submission"
msgstr "Collection submission"

msgid "Community visibility"
msgstr "Collection visibility"

msgid "Deleted community"
msgstr "Deleted collection"

msgid "Either community_id or community should be provided."
msgstr "Either collection_id or collection should be provided."

msgid ""
"Enable the 'Insights' tab that displays a community statistics dashboard."
msgstr ""
"Enable the 'Insights' tab that displays a collection statistics dashboard."

msgid "Featured communities"
msgstr "Featured collections"

msgid "Full administrative access to the entire community."
msgstr "Full administrative access to the entire collection."

msgid "In this community"
msgstr "In this collection"

msgid "Inclusion of subcommunity \"%(community)s\""
msgstr "Inclusion of child collection \"%(community)s\""

msgid "Invitation to join \"%(community)s\""
msgstr "Invitation to join \"%(community)s\""

msgid "Manage community"
msgstr "Manage collection"

msgid ""
"Members in your community are only visible to other members of the "
"community."
msgstr ""
"Members in your collection are only visible to other members of the "
"collection."

msgid "My communities"
msgstr "My collections"

msgid "New community"
msgstr "New collection"

msgid "New communities"
msgstr "New collections"

msgid "New subcommunity"
msgstr "New child collection"

msgid "No logo exists for this community."
msgstr "No logo exists for this collection."

msgid "Only members can submit records to the community."
msgstr "Only members can submit records to the collection."

msgid "Parent community does not accept subcommunities."
msgstr "Parent collection does not accept child collections."

msgid "Request to join \"%(community)s\""
msgstr "Request to join \"%(community)s\""

msgid "Search communities"
msgstr "Search collections"

msgid "Subcommunities"
msgstr "Subcollections"

msgid "Subcommunity"
msgstr "Subcollection"

msgid "Subcommunity invitation"
msgstr "Subcollection invitation"

msgid "Subcommunity request"
msgstr "Subcollection request"

msgid ""
"Submission to this community is only allowed to community members."
msgstr ""
"Submission to this collection is only allowed to collection members."

msgid ""
"Submissions to the community by default requires review, but all community "
"members can publish directly without review."
msgstr ""
"Submissions to the collection by default requires review, but all collection "
"members can publish directly without review."

msgid ""
"Submissions to the community by default requires review, but curators, "
"managers and owners can publish directly without review."
msgstr ""
"Submissions to the collection by default requires review, but curators, "
"managers and owners can publish directly without review."

msgid "The community is not public."
msgstr "The collection is not public."

msgid "The community is restricted to users with access."
msgstr "The collection is restricted to users with access."

msgid "The community was deleted."
msgstr "The collection was deleted."

#, python-format
msgid "The record %(rec_id)s in not included in the community %(com_id)s."
msgstr "The record %(rec_id)s in not included in the collection %(com_id)s."

msgid "The record is already included in this community."
msgstr "The record is already included in this collection."

msgid "The subjects related to the community"
msgstr "The subjects related to the collection"

#, python-format
msgid ""
"There is %(num)s request open for this community. Please, resolve it before "
"deleting this community."
msgid_plural ""
"There are %(num)s requests open for this community. Please, resolve all of "
"them before deleting this community."
msgstr[0] ""
"There is %(num)s request open for this collection. Please, resolve it "
"before deleting this collection."
msgstr[1] ""
"There are %(num)s requests open for this collection. Please, resolve all of "
"them before deleting this collection."

