msgid "A community must have at least one owner."
msgstr "A collection must have at least one owner."

msgid "A community with this identifier already exists."
msgstr "A collection with this identifier already exists."

msgid "A public record cannot be included in a restricted community."
msgstr "A public record cannot be included in a restricted collection."

msgid "A record should be part of at least 1 community."
msgstr "A record should be part of at least 1 collection."

msgid ""
"All authenticated users can submit records to the community. If the "
"community is restricted, then only members can submit records to it."
msgstr ""
"All authenticated users can submit records to the collection. If the "
"collection is restricted, then only members can submit records to it."

msgid "All submissions to the community must be reviewed."
msgstr "All submissions to the collection must be reviewed."

msgid "Assigned parent community cannot also have a parent."
msgstr "Assigned parent collection cannot also have a parent."

msgid "Assigned parent community cannot be the same as child."
msgstr "Assigned parent collection cannot be the same as child."

msgid "Assigned parent community does not exist."
msgstr "Assigned parent collection does not exist."

#, python-format
msgid "Cannot modify community visibility: %(reason)s"
msgstr "Cannot modify collection visibility: %(reason)s"

msgid "Cannot publish without a community."
msgstr "Cannot publish without a collection."

msgid "Cannot publish without selecting a community."
msgstr "Cannot publish without selecting a collection."

msgid "Cannot restrict a community with public records."
msgstr "Cannot restrict a collection with public records."

msgid ""
"Cannot set community as the default. The record has not been added to the "
"community."
msgstr ""
"Cannot set collection as the default. The record has not been added to the "
"collection."

msgid "Communities"
msgstr "Collections"

msgid "Community"
msgstr "Collection"

msgid "Community allowed to be a parent can't be a child."
msgstr "Collection allowed to be a parent can't be a child."

