# Ignore local virtualenv (if present) — root and under dependency checkouts
**/.venv

# Python bytecode and compiled files
__pycache__/
*.py[cod]
*$py.class
.Python
*.so

# Private / secrets — dotenv-style files anywhere (do not bake into images)
.env
**/.env
.env*
**/.env*
**/.envrc

.invenio.private*
docker/nginx_local/samlPrivateKey.key
docker/nginx_local/samlCertificate.key
docker-compose*

# Node — reinstalled during image build; huge if copied from dev machines
node_modules
**/node_modules

# pnpm content-addressable store inside dependency checkouts
**/.pnpm-store

# Cache directories
.mypy_cache/
**/.mypy_cache/
.pytest_cache/
**/.pytest_cache/
.ruff_cache/
**/.ruff_cache/
**/.coverage
htmlcov/
**/htmlcov/
**/.tox

# Git and vscode directories
.git/
**/.git*
.github/
**/.github*
.vscode/

# Logs
logs/*
**/test_logs
**/logs

# Scripts
scripts/experiments
scripts/sample_files

# Build artifacts
build/
site/build
site/kcworks.egg-info

# Static files
static/admin
static/dist
static/bootstrap
static/css
static/images/assets_library
static/js
static/templates
static/vendor
static/xsl

# Tests & docs — not used by Dockerfile (uv sync + webpack); CI uses full checkout
tests/
docs/
docs/private/

# Path dependencies under site/kcworks/dependencies: tests, nested fixtures, docs,
# and legacy nested submodule dirs (monorepo uses sibling ../ peers; Docker only needs uv+webpack)
site/kcworks/dependencies/**/tests/
site/kcworks/dependencies/**/tests/fixtures/
site/kcworks/dependencies/**/docs/
site/kcworks/dependencies/**/invenio_record_importer_kcworks/dependencies/
site/kcworks/dependencies/**/invenio_group_collections_kcworks/dependencies/
